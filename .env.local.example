# Diese Datei zu .env.local kopieren und mit echten Werten aus Supabase füllen
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Nur serverseitig (Preis-Cron). NIEMALS ins Frontend/Repo committen!
# Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key
# Frei wählbares Geheimnis, das den Cron-Endpunkt schützt
CRON_SECRET=ein-langes-zufaelliges-geheimnis
